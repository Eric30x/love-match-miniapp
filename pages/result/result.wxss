.container {
  min-height: 100vh;
  background-color: #F2F2F2;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.premium-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 48rpx;
  position: relative;
  overflow: hidden;
  padding: 80rpx 40rpx 60rpx;
  box-shadow: 0 40rpx 100rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}

.deco-line {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 120rpx;
  height: 8rpx;
  border-radius: 0 0 8rpx 8rpx;
}

.header-section {
  text-align: center;
  margin-bottom: 60rpx;
}

.user-label {
  font-size: 24rpx;
  color: #A0A0A0;
  letter-spacing: 6rpx;
}

.type-title {
  font-size: 60rpx;
  font-weight: 700;
  margin: 20rpx 0;
  line-height: 1.3;
}

.tag-group {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 100rpx;
  font-weight: 500;
}

.analysis-box {
  background: #FAFAFA;
  padding: 60rpx 40rpx;
  border-radius: 32rpx;
  position: relative;
  margin-bottom: 50rpx;
}

.quote-mark {
  font-size: 60rpx;
  color: #E0E0E0;
  position: absolute;
  top: 10rpx;
  left: 20rpx;
}

.quote-mark.rotate {
  top: auto;
  bottom: -10rpx;
  left: auto;
  right: 20rpx;
}

.description {
  font-size: 30rpx;
  color: #4A4A4A;
  line-height: 1.8;
  display: block;
}

.score-section {
  text-align: center;
  margin-bottom: 50rpx;
}

.score-circle {
  display: inline-flex;
  align-items: baseline;
}

.score-num {
  font-size: 100rpx;
  font-weight: 300;
  color: #1A1A1A;
}

.score-unit {
  font-size: 32rpx;
  color: #1A1A1A;
  margin-left: 4rpx;
}

.score-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  letter-spacing: 4rpx;
  margin-top: -10rpx;
}

.detail-card {
  background: #FAFAFA;
  border-radius: 28rpx;
  padding: 30rpx;
  margin-bottom: 28rpx;
}

.detail-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 18rpx;
}

.detail-text {
  display: block;
  font-size: 28rpx;
  color: #4A4A4A;
  line-height: 1.8;
}

.bullet-item {
  font-size: 27rpx;
  color: #4A4A4A;
  line-height: 1.8;
  margin-bottom: 8rpx;
}

.metric-row {
  margin-top: 18rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 25rpx;
  color: #4A4A4A;
}

.metric-bar {
  margin-top: 10rpx;
  width: 100%;
  height: 12rpx;
  background: #ECECEC;
  border-radius: 999rpx;
  overflow: hidden;
}

.metric-fill {
  height: 100%;
  border-radius: 999rpx;
}

.footer-btns {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 20rpx;
}

.main-btn {
  width: 100% !important;
  height: 100rpx;
  border-radius: 50rpx;
  color: #FFF;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.sub-btn {
  width: 100% !important;
  height: 100rpx;
  border-radius: 50rpx;
  background: #FFF;
  color: #1A1A1A;
  font-size: 28rpx;
  border: 1rpx solid #E0E0E0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.subtype-badge{
  display:inline-block;
  margin-top:12rpx;
  padding:10rpx 26rpx;

  font-size:26rpx;
  font-weight:600;
  color:#a05aa1;

  background:linear-gradient(135deg,#f7e8f4,#efe6f7);
  border-radius:999rpx;

  letter-spacing:2rpx;
}
.subtype-label{
  font-size:24rpx;
  color:#888;
  margin-right:12rpx;
}
