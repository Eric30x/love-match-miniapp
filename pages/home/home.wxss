page {
  background: linear-gradient(180deg, #f8f7f4 0%, #f5f3ef 50%, #f8f7f4 100%);
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica,
    "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  color: #333333;
}

.container {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 78rpx 46rpx 58rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.container::before {
  content: "";
  position: absolute;
  top: 110rpx;
  left: -40rpx;
  width: 220rpx;
  height: 220rpx;
  background: rgba(255, 214, 214, 0.18);
  border-radius: 50%;
  filter: blur(20rpx);
}

.container::after {
  content: "";
  position: absolute;
  right: -30rpx;
  top: 360rpx;
  width: 180rpx;
  height: 180rpx;
  background: rgba(255, 234, 214, 0.18);
  border-radius: 50%;
  filter: blur(24rpx);
}

.header,
.hero-image-card,
.message-section,
.action-section {
  position: relative;
  z-index: 2;
}

.header {
  width: 100%;
  text-align: center;
  margin-bottom: 54rpx;
}

.title {
  display: block;
  font-size: 62rpx;
  font-weight: 700;
  color: #1d1d1f;
  letter-spacing: 2rpx;
  margin-bottom: 18rpx;
  text-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.04);
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #9b9b9b;
  line-height: 1.9;
  letter-spacing: 1rpx;
}

.hero-image-card {
  width: 100%;
  height: 430rpx;
  border-radius: 32rpx;
  overflow: hidden;
  position: relative;
  background: #ffffff;
  box-shadow: 0 20rpx 50rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 42rpx;
}

.hero-image {
  width: 100%;
  height: 100%;
  display: block;
}

.image-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.06) 0%,
    rgba(255, 255, 255, 0) 40%,
    rgba(0, 0, 0, 0.04) 100%
  );
}

.message-section {
  width: 100%;
  text-align: center;
  margin-bottom: 64rpx;
  padding: 6rpx 10rpx 0;
  box-sizing: border-box;
}

.message-line {
  display: block;
  width: 100%;
  font-size: 31rpx;
  line-height: 1.95;
  color: #5b5b5b;
  letter-spacing: 1rpx;
  word-break: keep-all;
  white-space: normal;
  text-shadow: 0 2rpx 6rpx rgba(255, 255, 255, 0.3);
}

.highlight {
  margin-top: 14rpx;
  font-size: 38rpx;
  line-height: 2;
  color: #de7a8d;
  font-weight: 700;
  letter-spacing: 2rpx;
  text-shadow: 0 0 14rpx rgba(222, 122, 141, 0.18);
}

.action-section {
  width: 100%;
  margin-top: auto;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.primary-btn {
  width: 100%;
  height: 98rpx;
  line-height: 98rpx;
  border-radius: 49rpx;
  background: linear-gradient(135deg, #232323 0%, #3a3a3a 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  letter-spacing: 6rpx;
  box-shadow: 0 16rpx 30rpx rgba(31, 31, 31, 0.2);
}

.primary-btn::after {
  border: none;
}

.primary-btn:active {
  transform: scale(0.98);
}

.primary-btn.disabled {
  background: linear-gradient(135deg, #dcdcdc 0%, #e7e7e7 100%);
  color: #aaaaaa;
  box-shadow: none;
}

.agreement {
  margin-top: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  font-size: 24rpx;
  color: #8e8e8e;
}

.checkbox {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #cfcfcf;
  border-radius: 10rpx;
  margin-right: 12rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.8);
  transition: all 0.2s ease;
}

.checkbox.checked {
  background: #1f1f1f;
  border-color: #1f1f1f;
  box-shadow: 0 6rpx 14rpx rgba(31, 31, 31, 0.16);
}

.tick {
  color: #ffffff;
  font-size: 20rpx;
  line-height: 1;
}

.agreement-text {
  color: #8b8b8b;
}

.link {
  color: #1f1f1f;
  font-weight: 600;
  margin-left: 4rpx;
}

/* 入场动画 */
.fade-down,
.fade-up {
  opacity: 0;
  animation-fill-mode: forwards;
  animation-timing-function: ease;
}

.fade-down {
  animation-name: fadeDown;
  animation-duration: 0.9s;
}

.fade-up {
  animation-name: fadeUp;
  animation-duration: 0.9s;
}

.delay-1 { animation-delay: 0.1s; }
.delay-2 { animation-delay: 0.25s; }
.delay-3 { animation-delay: 0.4s; }
.delay-4 { animation-delay: 0.55s; }
.delay-5 { animation-delay: 0.7s; }
.delay-6 { animation-delay: 0.85s; }
.delay-7 { animation-delay: 1s; }
.delay-8 { animation-delay: 1.15s; }
.delay-9 { animation-delay: 1.3s; }
.delay-10 { animation-delay: 1.45s; }

@keyframes fadeDown {
  0% {
    opacity: 0;
    transform: translateY(-24rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeUp {
  0% {
    opacity: 0;
    transform: translateY(26rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 图片轻微浮动 */
.float-gentle {
  animation: fadeUp 0.9s ease forwards, floating 4.5s ease-in-out infinite;
}

@keyframes floating {
  0% {
    transform: translateY(0rpx);
  }
  50% {
    transform: translateY(-8rpx);
  }
  100% {
    transform: translateY(0rpx);
  }
}